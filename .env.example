# ── ArchonHQ Content Engine — Environment Variables ──────────────────────────
# Copy this file to .env and fill in your values.
# Each variable is annotated with which script(s) use it.

# ── Core API Keys ─────────────────────────────────────────────────────────────

# OpenRouter API key — used by most scripts for LLM calls via openrouter.ai.
# Required by: idea_generator.py, draft_generator.py, substack_publisher.py,
#              distribution_engine.py, growth_engine.py, llm_prose_fix.py
OPENROUTER_API_KEY=

# OpenAI API key — used for hero image generation (gpt-image-1 / gpt-image-2).
# Required by: substack_publisher.py, gen_heroes.py
OPENAI_API_KEY=

# Resend API key — used for email-based Substack draft publishing.
# Required by: substack_publisher.py
RESEND_API_KEY=

# ── Substack Publishing ──────────────────────────────────────────────────────

# Sender email address for Substack drafts (must be verified in Resend).
# Default: navi@archonhq.ai
# Used by: substack_publisher.py
RESEND_FROM_EMAIL=

# Substack post-by-email address (format: post@yourpub.substack.com).
# Default: post@substack.com
# Used by: substack_publisher.py
ARCHONHQ_SUBSTACK_EMAIL=

# ── Dev.to Cross-Posting ─────────────────────────────────────────────────────

# Dev.to API key for cross-posting articles.
# Get one at: https://dev.to/settings/extensions
# Required by: distribution_engine.py, crosspost.py, growth_engine.py
ARCHONHQ_DEVTO_API_KEY=

# ── Model Overrides ──────────────────────────────────────────────────────────
# Each pipeline stage can use a different model via OpenRouter.
# Defaults are set in each script; override here if desired.

# Model for idea generation stage.
# Default: deepseek/deepseek-chat-v3-0324
# Used by: idea_generator.py
IDEA_MODEL=

# Model for draft generation stage.
# Default: z-ai/glm-5.1
# Used by: draft_generator.py
DRAFT_MODEL=

# Model for publishing/scene-generation stage (hero image prompt composition).
# Default: openai/gpt-4.1-nano
# Used by: substack_publisher.py
PUBLISH_MODEL=

# Model for distribution/social-copy generation stage.
# Default: deepseek/deepseek-chat-v3-0324
# Used by: distribution_engine.py
DISTRIBUTE_MODEL=
